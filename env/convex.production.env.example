# Required in the Convex production deployment.
CLERK_JWT_ISSUER_DOMAIN=
MUX_TOKEN_ID=
MUX_TOKEN_SECRET=
MUX_WEBHOOK_SECRET=
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_BASIC_MONTHLY=
STRIPE_PRICE_PRO_MONTHLY=
RAILWAY_ACCESS_KEY_ID=
RAILWAY_SECRET_ACCESS_KEY=
RAILWAY_ENDPOINT=https://your-storage-endpoint

# Required for production billing redirects and absolute links.
APP_SITE_URL=https://loam.video
VITE_CONVEX_SITE_URL=https://loam.video

# Recommended when the public bucket URL differs from the API endpoint.
RAILWAY_PUBLIC_URL=https://your-public-bucket-url

# Optional overrides.
RAILWAY_BUCKET_NAME=videos
RAILWAY_REGION=us-east-1
RAILWAY_PUBLIC_URL_INCLUDE_BUCKET=true

# Optional watch notification emails.
RESEND_API_KEY=
NOTIFICATION_FROM_EMAIL=Loam <notify@loam.video>

# Optional for future signed Mux playback.
MUX_SIGNING_KEY=
MUX_PRIVATE_KEY=
