{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Loam Desktop Recorder",
  "version": "0.1.0",
  "identifier": "so.loam.desktop",
  "build": {
    "beforeDevCommand": "bun run dev",
    "beforeBuildCommand": "bun run build",
    "devUrl": "http://localhost:1420",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Loam Desktop Recorder",
        "width": 1360,
        "height": 900,
        "minWidth": 1120,
        "minHeight": 760,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": [
      "app",
      "dmg"
    ],
    "category": "Productivity",
    "shortDescription": "Native macOS recorder that uploads directly to Loam share links.",
    "longDescription": "Loam Desktop Recorder is a focused macOS capture client for recording a display or window, uploading the resulting file to Loam, and landing on a shareable link with minimal friction.",
    "createUpdaterArtifacts": false,
    "macOS": {
      "minimumSystemVersion": "12.7",
      "dmg": {
        "windowSize": {
          "width": 720,
          "height": 440
        },
        "appPosition": {
          "x": 190,
          "y": 180
        },
        "applicationFolderPosition": {
          "x": 520,
          "y": 180
        }
      }
    }
  }
}
